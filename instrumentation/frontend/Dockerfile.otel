# Dockerfile overlay — add OTel instrumentation to frontend build
# Build: docker build -f Dockerfile.otel -t frontend:otel .

FROM golang:1.22-alpine AS builder
WORKDIR /src

COPY otel_instrumentation.go ./
COPY go.mod go.sum ./
RUN go mod download

# Copy upstream frontend source and merge instrumentation
COPY . .
RUN CGO_ENABLED=0 go build -o /frontend .

FROM alpine:3.19
RUN apk add --no-cache ca-certificates
COPY --from=builder /frontend /frontend
EXPOSE 8080
ENTRYPOINT ["/frontend"]
